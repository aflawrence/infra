---
# Encrypt with: ansible-vault encrypt group_vars/forge/secret.yml
#
# hacluster is the built-in pcs auth user. Corosync itself uses a generated
# keyfile; this password authenticates `pcs` API calls between nodes.
forge_cluster_hacluster_password: "change-me-long-random"

# Restic repository password. Without this you CANNOT restore — store it
# outside of the backup itself as well (password manager, printed copy).
forge_backup_restic_password: "change-me-different-long-random"

# Env vars for the restic backend. Example for Backblaze B2:
forge_backup_restic_env:
  B2_ACCOUNT_ID: "xxxxxxxxxxxx"
  B2_ACCOUNT_KEY: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
